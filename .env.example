# Copy this file to .env and fill in your real key.
# Keep .env private. Do not commit API keys.

API_PORT=5180

# Recommended for this portfolio chatbot.
DASHSCOPE_API_KEY=your_dashscope_api_key_here
AI_MODEL=qwen-turbo
AI_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions

# Optional admin and contact settings.
ADMIN_USER=admin
ADMIN_PASS=change_this_password
ADMIN_SECRET=change_this_to_a_long_random_string
CONTACT_NOTIFY_EMAIL=1654387747@qq.com
